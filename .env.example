# Copy this file to .env and fill in real values
RCLONE_CONFIG_PASS=your-rclone-config-password
RCLONE_CONFIG_DIR=/Users/your-user/.config/rclone
MACCY_DATA_DIR=/Users/your-user/Library/Containers/org.p0deje.Maccy/Data/Library/Application Support/Maccy
TZ=Asia/Ho_Chi_Minh

# Sync/health tuning (defaults shown)
SYNC_INTERVAL_SECONDS=1800
RETRY_WAIT_SECONDS=1800
MAX_FAIL_STREAK=48
HEALTH_MAX_LAG_SECONDS=86400
